# Database
DATABASE_URL="postgresql://batuflow:batuflow_secret@localhost:5432/batuflow?schema=public"

# Redis
REDIS_URL="redis://localhost:6379"

# NextAuth
AUTH_SECRET="generate-a-random-secret-here"
AUTH_URL="http://localhost:3000"

# App
NEXT_PUBLIC_APP_URL="http://localhost:3000"
NEXT_PUBLIC_APP_NAME="BatuFlow"

# Google Maps (optional - for customer GPS picker)
NEXT_PUBLIC_GOOGLE_MAPS_API_KEY=""

# WhatsApp Gateway (Phase 7)
# WHATSAPP_API_URL=""
# WHATSAPP_API_KEY=""

# Upload limits
MAX_IMAGE_SIZE_MB=1
MAX_IMPORT_ROWS=5000
