# =============================================================================
# BatuFlow Environment Variables
# Copy to .env and fill in values. Required for: db push, seed, NextAuth, Redis.
# =============================================================================

# -----------------------------------------------------------------------------
# Database (required)
# PostgreSQL connection string. Use same credentials as docker-compose if local.
# -----------------------------------------------------------------------------
DATABASE_URL="postgresql://batuflow:batuflow@localhost:5432/batuflow"

# -----------------------------------------------------------------------------
# Redis (optional for queues; defaults to localhost:6379)
# Used by audit queue / background jobs. App runs without it but queue features disabled.
# -----------------------------------------------------------------------------
REDIS_URL="redis://localhost:6379"

# -----------------------------------------------------------------------------
# NextAuth (required)
# AUTH_SECRET: Must be a strong random string in production (e.g. openssl rand -base64 32).
# AUTH_URL: Base URL of the app (e.g. https://your-domain.com).
# -----------------------------------------------------------------------------
AUTH_SECRET="generate-a-random-secret-here"
AUTH_URL="http://localhost:3000"

# -----------------------------------------------------------------------------
# App (optional)
# NEXT_PUBLIC_APP_URL: Used for links in emails/notifications. Defaults to AUTH_URL.
# -----------------------------------------------------------------------------
NEXT_PUBLIC_APP_URL="http://localhost:3000"
NEXT_PUBLIC_APP_NAME="BatuFlow"

# -----------------------------------------------------------------------------
# Optional integrations
# -----------------------------------------------------------------------------
# Google Maps API key — for customer address GPS picker on maps
# NEXT_PUBLIC_GOOGLE_MAPS_API_KEY=""

# WhatsApp gateway (if Phase 7 notification channel enabled)
# WHATSAPP_API_URL=""
# WHATSAPP_API_KEY=""

# -----------------------------------------------------------------------------
# Limits (optional)
# -----------------------------------------------------------------------------
# MAX_IMAGE_SIZE_MB=1
# MAX_IMPORT_ROWS=5000
